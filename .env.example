HOST=0.0.0.0
EXECUTOR_BASE_URL=http://127.0.0.1:3000
VITE_DEMO_API_BASE_URL=http://127.0.0.1:8787
MICROSANDBOX_IMAGE_DATA_SCIENCE=hari31416/sandbox-data-science:py312-v1
